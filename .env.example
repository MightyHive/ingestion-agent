# Copy to .env and fill in values (never commit .env).

PROJECT_ID_LLM=
PROJECT_ID_DATA=
LOCATION=us-central1
MODEL_NAME=gemini-2.5-flash
TEMPERATURE=0.0
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Local ingestion API: path to tenant registry (required for POST /api/run with real connectors).
# API uses tenant_id "dev" — key must match in config/tenants.json.
# Run uvicorn from src/:  cd src && RUN_MODE=api uvicorn api:app --reload --port 8000
MDS_TENANTS_FILE=../config/tenants.json

# Credentials module (Phase 5)
# Backend for storing credential tokens. Use "local" for dev (no GCP required).
MDS_SECRETS_BACKEND=local
# MDS_DB_PATH=../mds_credentials.db        # SQLite path (default: repo root)
# Para producción con GCP Secret Manager:
# MDS_SECRETS_BACKEND=gcp
# MDS_GCP_PROJECT=monks-mds-dev
# MDS_SA_CONNECTION_KEY=/path/to/sm-writer.json
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json
