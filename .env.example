# Copy to .env and fill in values (never commit .env).

PROJECT_ID_LLM=
PROJECT_ID_DATA=
LOCATION=us-central1
MODEL_NAME=gemini-2.5-flash
TEMPERATURE=0.0
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Local ingestion API: path to tenant registry (required for POST /api/run with real connectors).
# API uses tenant_id "dev" — key must match in config/tenants.json.
# Run uvicorn from src/:  cd src && RUN_MODE=api uvicorn api:app --reload --port 8000
MDS_TENANTS_FILE=../config/tenants.json
