# ==========================================
# 🔒 Entorno y Secretos (¡CRÍTICO!)
# ==========================================
.env
.env.*
!.env.example
!**/.env.example
*.key
*.pem
# Solo ignorar JSONs en la raíz por si descargas las Service Accounts de GCP 
/*.json 

# ==========================================
# 🐍 Python & Entorno Virtual
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
build/
dist/
*.egg-info/

# ==========================================
# 📂 Archivos Específicos de tu Plataforma
# ==========================================
# Ignorar los logs de observabilidad que generamos con -obs
traces/
*.log

# SQLite leftovers (the legacy AsyncSqliteSaver checkpointer was removed
# in Phase 4 but old local DBs may still be on developer machines).
checkpoints.db
checkpoints.db-wal
checkpoints.db-shm
_test_cp.db

# pytest tmp dirs and basetemp
.pytest_cache/
/tmp/pytest-mds/

# ==========================================
# 💻 IDEs y Sistema Operativo
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ==========================================
# 📂 Frontend
# ==========================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
frontend/*.egg-info/
frontend/*.py[cod]
frontend/$py.class
frontend/env/   