# ============================================================================
# Frontend env template — copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored. NEVER commit real secrets.
# ============================================================================

# Backend API (FastAPI) — when running uvicorn locally on port 8000:
NEXT_PUBLIC_API_URL=http://localhost:8000

# Toggle mock data layer. Keep `false` for the real Fase 5 flow against the
# backend; set to `true` only if you want to demo the UI without backend.
NEXT_PUBLIC_MOCK=false

# ---------------------------------------------------------------------------
# Multi-tenant (Fase 5)
# ---------------------------------------------------------------------------
# CSV list of tenants that appear in the "CLIENT" dropdown in the header.
# Each value must match a row in `~/.mds/tenants.json` on the backend host
# (and have its secrets loaded in Secret Manager as
# `client_<tenant_id>_<platform>_<key>`).
NEXT_PUBLIC_TENANTS=dev,cliente1

# Tenant pre-selected on first load (must be one of the values above).
NEXT_PUBLIC_DEFAULT_TENANT_ID=cliente1

# ---------------------------------------------------------------------------
# NextAuth (Google sign-in) — generate secret with: openssl rand -base64 32
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Web application client).
# Authorized redirect URI in Google Cloud Console must be:
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
